import React, { useState, useEffect, useContext } from 'react';
import { useNavigate } from 'react-router-dom';
import { AuthContext } from '../contexts/AuthContext';
import { apiRequest } from '../utils/api';

const SalesmanAttendance = () => {
  const { user } = useContext(AuthContext);
  const navigate = useNavigate();
  const [todayAttendance, setTodayAttendance] = useState(null);
  const [attendanceHistory, setAttendanceHistory] = useState([]);
  const [currentTime, setCurrentTime] = useState(new Date());
  const [location, setLocation] = useState({ latitude: null, longitude: null });
  const [loading, setLoading] = useState(true);
  const [photoFile, setPhotoFile] = useState(null);
  const [photoPreview, setPhotoPreview] = useState(null);
  const [showCamera, setShowCamera] = useState(false);

  useEffect(() => {
    if (user) {
      fetchAttendance();
      getCurrentLocation();
    }

    const timer = setInterval(() => {
      setCurrentTime(new Date());
    }, 1000);

    return () => clearInterval(timer);
  }, [user]);

  const fetchAttendance = async () => {
    try {
      const today = new Date().toISOString().split('T')[0];
      const [todayData, historyData] = await Promise.all([
        apiRequest(`/api/sales/my-attendance?date=${today}`).catch(() => []),
        apiRequest('/api/sales/my-attendance?days=30').catch(() => [])
      ]);

      setTodayAttendance(todayData[0] || null);
      setAttendanceHistory(historyData || []);
    } catch (error) {
      console.error('Failed to fetch attendance:', error);
    } finally {
      setLoading(false);
    }
  };

  const getCurrentLocation = () => {
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (position) => {
          setLocation({
            latitude: position.coords.latitude,
            longitude: position.coords.longitude
          });
        },
        (error) => {
          console.warn('Geolocation unavailable, using default location:', error.message);
          // Set default location if geolocation fails (office location or 0,0)
          setLocation({
            latitude: 0,
            longitude: 0
          });
        },
        {
          enableHighAccuracy: false,
          timeout: 5000,
          maximumAge: 0
        }
      );
    } else {
      // Browser doesn't support geolocation
      console.warn('Geolocation not supported, using default location');
      setLocation({
        latitude: 0,
        longitude: 0
      });
    }handlePhotoCapture = (e) => {
    const file = e.target.files[0];
    if (file) {
      setPhotoFile(file);
      const reader = new FileReader();
      reader.onloadend = () => {
        setPhotoPreview(reader.result);
      };
      reader.readAsDataURL(file);
    }
  };

  const removePhoto = () => {
    setPhotoFile(null);
    setPhotoPreview(null);
  };

  const markAttendance = async (type) => {
    if (!photoFile) {
      alert('Please upload a shop/site photo before marking attendance!');
      return;
    }

    try {
      const formData = new FormData();
      formData.append('time', new Date().toISOString());
      formData.append('location', `${location.latitude}, ${location.longitude}`);
      formData.append('latitude', location.latitude);
      formData.append('longitude', location.longitude);
      formData.append('status', type === 'checkin' ? 'Present' : 'Checked Out');
      formData.append('photo', photoFile);

      const token = localStorage.getItem('token');
      const response = await fetch('http://localhost:8000/api/sales/attendance', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${token}`
        },
        body: formData
      });

      if (!response.ok) {
        throw new Error('Failed to mark attendance');
      }

      alert(`Successfully ${type === 'checkin' ? 'checked in' : 'checked out'}!`);
      setPhotoFile(null);
      setPhotoPreview(null);
      fetchAttendance();
    } catch (error) {
      console.error('Failed to mark attendance:', error);
      alert('Failed to mark attendance: ' + error.message);
    }
  };

  if (loading) {
    return <div className="loading">⏳ Loading attendance...</div>;
  }

  return (
    <div className="attendance-page">
      <div className="page-header">
        <div>
          <h1>⏰ Attendance</h1>
          <p>Mark your daily attendance</p>
        </div>
        <button className="btn-back" onClick={() => navigate('/salesman/dashboard')}>
          ← Back
        </button>
      </div>

      {/* Current Time & Status */}
      <div className="attendance-clock">
        <div className="clock-display">
          <div className="time">
            {currentTime.toLocaleTimeString('en-US', {
              hour: '2-digit',
              minute: '2-digit',
              second: '2-digit'
            })}
          </div>
          <div className="date">
            {currentTime.toLocaleDateString('en-US', {
              weekday: 'long',
              month: 'long',
              day: 'numeric',
              year: 'numeric'
            })}
          </div>
        </div>

        <div className="status-card">
          {todayAttendance ? (
            <>
              <div className="status-icon checked-in">✅</div>
              <h3>Checked In</h3>
              <p>
                {new Date(todayAttendance.date).toLocaleTimeString('en-US', {
                  hour: '2-digit',
                  minute: '2-digit'
                })}
              </p>
            </>
          ) : (
            <>
              <div className="status-icon not-checked">⏰</div>
              <h3>Not Checked In</h3>
              <p>Please mark your attendance</p>
            </>
          )}
        </div>

        <div className="attendance-actions">
          {!todayAttendance ? (
            <>
              {/* Photo Upload Section */}
              <div className="photo-upload-section">
                <h3>📸 Shop/Site Photo Required</h3>
                
                {!photoPreview ? (
                  <div className="photo-upload-container">
                    <label htmlFor="photo-upload" className="photo-upload-btn">
                      📷 Capture/Upload Photo
                      <input
                        id="photo-upload"
                        type="file"
                        accept="image/*"
                        capture="environment"
                        onChange={handlePhotoCapture}
                        style={{ display: 'none' }}
                      />
                    </label>
                    <p className="upload-hint">Take a photo of the shop/site you're visiting</p>
                  </div>
                ) : (
                  <div className="photo-preview-container">
                    <img src={photoPreview} alt="Site preview" className="photo-preview" />
                    <button className="btn-remove-photo" onClick={removePhoto}>
                      🗑️ Remove Photo
                    </button>
                  </div>
                )}
              </div>

              <button 
                className="btn-checkin"
                onClick={() => markAttendance('checkin')}
                disabled={!location.latitude || !photoFile}
              >
                ✓ Check In
                {!location.latitude && <span className="btn-note">Getting location...</span>}
                {!photoFile && location.latitude && <span className="btn-note">Photo required</span>}
              </button>
            </>
          ) : (
            <button className="btn-checkout" disabled>
              ✅ Already Checked In
            </button>
          )}
        </div>

        {location.latitude && (
          <div className="location-info">
            📍 Location: {location.latitude.toFixed(4)}, {location.longitude.toFixed(4)}
          </div>
        )}
      </div>

      {/* Attendance History */}
      <div className="attendance-history">
        <h2>📊 Attendance History ({attendanceHistory.length} days)</h2>
        {attendanceHistory.length === 0 ? (
          <div className="empty-state">
            <p>No attendance records found</p>
          </div>
        ) : (
          <div className="history-list">
            <table>
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Day</th>
                  <th>Check In</th>
                  <th>Status</th>
                  <th>Location</th>
                </tr>
              </thead>
              <tbody>
                {attendanceHistory.map(record => (
                  <tr key={record.id}>
                    <td>
                      {new Date(record.date).toLocaleDateString('en-US', {
                        month: 'short',
                        day: 'numeric',
                        year: 'numeric'
                      })}
                    </td>
                    <td>
                      {new Date(record.date).toLocaleDateString('en-US', {
                        weekday: 'short'
                      })}
                    </td>
                    <td className="time-cell">
                      {new Date(record.date).toLocaleTimeString('en-US', {
                        hour: '2-digit',
                        minute: '2-digit'
                      })}
                    </td>
                    <td>
                      <span className={`status-badge ${record.status.toLowerCase().replace(' ', '-')}`}>
                        {record.status}
                      </span>
                    </td>
                    <td className="location-cell">
                      {record.location || 'N/A'}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      <style>{`
        .attendance-page {
          padding: 20px;
          background: #f5f7fa;
          min-height: 100vh;
        }

        .page-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 30px;
          background: white;
          padding: 25px;
          border-radius: 12px;
          box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .page-header h1 {
          margin: 0 0 5px 0;
        }

        .page-header p {
          margin: 0;
          color: #666;
        }

        .btn-back {
          padding: 12px 24px;
          background: #6c757d;
          color: white;
          border: none;
          border-radius: 8px;
          font-weight: 600;
          cursor: pointer;
        }

        .attendance-clock {
          background: white;
          padding: 40px;
          border-radius: 12px;
          box-shadow: 0 2px 8px rgba(0,0,0,0.1);
          margin-bottom: 20px;
          text-align: center;
        }

        .clock-display {
          margin-bottom: 30px;
        }

        .time {
          font-size: 64px;
          font-weight: 700;
          color: #667eea;
          margin-bottom: 10px;
        }

        .date {
          font-size: 20px;
          color: #666;
        }

        .status-card {
          background: #f8f9fa;
          padding: 30px;
          border-radius: 12px;
          margin-bottom: 30px;
        }

        .status-icon {
          font-size: 64px;
          margin-bottom: 15px;
        }

        .status-card h3 {
          margin: 0 0 10px 0;
          font-size: 24px;
        }

        .status-card p {
          margin: 0;
          color: #666;
          font-size: 18px;
        }

        .attendance-actions {
          margin-bottom: 20px;
        }

        .btn-checkin,
        .btn-checkout {
          padding: 16px 48px;
          font-size: 18px;
          font-weight: 700;
          border: none;
          border-radius: 12px;
          cursor: pointer;
          transition: all 0.3s;
        }

        .btn-checkin {
          background: #28a745;
          color: white;
        }

        .btn-checkin:hover:not(:disabled) {
          background: #218838;
          transform: translateY(-2px);
        }

        .btn-checkin:disabled,
        .btn-checkout:disabled {
          background: #e9ecef;
          color: #6c757d;
          cursor: not-allowed;
        }

        .btn-note {
          display: block;
          font-size: 12px;
          margin-top: 5px;
          font-weight: normal;
        }

        .location-info {
          color: #666;
          font-size: 14px;
          margin-top: 20px;
        }

        .attendance-history {
          background: white;
          padding: 25px;
          border-radius: 12px;
          box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .attendance-history h2 {
          margin: 0 0 20px 0;
        }

        .history-list table {
          width: 100%;
          border-collapse: collapse;
        }

        .history-list th {
          background: #f8f9fa;
          padding: 12px;
          text-align: left;
          font-weight: 700;
          color: #1a1a1a;
          border-bottom: 2px solid #e0e0e0;
        }

        .history-list td {
          padding: 12px;
          border-bottom: 1px solid #f0f0f0;
          color: #666;
        }

        .history-list tr:hover {
          background: #f8f9fa;
        }

        .time-cell {
          font-weight: 600;
          color: #1a1a1a;
        }

        .location-cell {
          font-size: 12px;
        }

        .status-badge {
          padding: 4px 12px;
          border-radius: 12px;
          font-size: 12px;
          font-weight: 700;
          color: white;
        }

        .status-badge.present {
          background: #28a745;
        }

        .status-badge.checked-out {
          background: #6c757d;
        }

        .empty-state {
          text-align: center;
          padding: 40px;
          color: #999;
        }

        .loading {
          text-align: center;
          padding: 100px 20px;
          font-size: 24px;
          color: #666;
        }

        @media (max-width: 768px) {
          .time {
            font-size: 48px;
          }

          .date {
            font-size: 16px;
          }

          .status-card h3 {
            font-size: 20px;
          }

          .history-list {
            overflow-x: auto;
          }

          .history-list table {
            min-width: 600px;
          }
        }
      `}</style>
    </div>
  );
};

export default SalesmanAttendance;
